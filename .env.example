# Absolute site URL for Open Graph / metadata (set in production, e.g. https://yoursite.com)
# NEXT_PUBLIC_SITE_URL=https://example.com

# App download URL — TestFlight beta link or App Store product URL
# NEXT_PUBLIC_APP_STORE_URL=https://testflight.apple.com/join/8M8EJsUE

# Buttondown newsletter API key (server-only — no NEXT_PUBLIC_ prefix)
# BUTTONDOWN_API_KEY=your_buttondown_api_key_here
